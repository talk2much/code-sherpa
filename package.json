{
  "name": "code-sherpa",
  "version": "0.1.0",
  "description": "智能代码治理 Agent——面向大型 TypeScript monorepo 的符号依赖分析工具",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-sherpa": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "index:build": "tsx src/cli.ts index:build",
    "index:update": "tsx src/cli.ts index:update",
    "index:verify": "tsx src/cli.ts index:verify",
    "index:stats": "tsx src/cli.ts index:stats",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "openai": "^4.86.1",
    "yaml": "^2.7.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
